{
  "name": "ovni-ai-wrapper",
  "version": "1.0.0",
  "description": "OVNI AI — Multi-tenant SaaS wrapper for Anthropic Claude API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:seed": "tsx src/db/seed.ts",
    "db:migrate": "node-pg-migrate up --config migrate.json",
    "db:migrate:down": "node-pg-migrate down --config migrate.json",
    "db:migrate:create": "node-pg-migrate create --config migrate.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-ses": "^3.1024.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "node-pg-migrate": "^8.0.4",
    "otpauth": "^9.3.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0",
    "pg-boss": "^10.1.1",
    "stripe": "^17.3.0",
    "twilio": "^5.3.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
